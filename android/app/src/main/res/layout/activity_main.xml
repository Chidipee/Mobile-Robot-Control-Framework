<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/neo_bg"
    android:padding="16dp">

    <!-- ═══ HEADER BAR ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="12dp">

        <!-- Left: LED + Connection status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/led_indicator"
                android:layout_width="@dimen/neo_led_size"
                android:layout_height="@dimen/neo_led_size"
                android:background="@drawable/led_disconnected" />

            <TextView
                android:id="@+id/connection_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-black"
                android:text="@string/offline"
                android:textColor="@color/neo_red"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Center: Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.12"
            android:text="@string/title"
            android:textColor="@color/neo_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Right: Emergency Stop -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end">

            <Button
                android:id="@+id/stop_button"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:background="@drawable/neo_button_stop"
                android:fontFamily="sans-serif-black"
                android:minWidth="80dp"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:stateListAnimator="@null"
                android:text="@string/stop"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ═══ STATUS CARD ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/neo_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="11dp"
        android:paddingEnd="16dp"
        android:paddingBottom="11dp">

        <TextView
            android:id="@+id/firmware_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="\u2014"
            android:textColor="@color/neo_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="2dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/neo_border" />

        <TextView
            android:id="@+id/uptime_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/connect_hint"
            android:textColor="@color/neo_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="2dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@color/neo_border" />

        <TextView
            android:id="@+id/clients_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="@string/wifi_name"
            android:textColor="@color/neo_text_secondary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ═══ JOYSTICK AREA ═══ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:layout_weight="1">

        <com.example.mobile_robot_android.JoystickView
            android:id="@+id/joystick_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- ═══ SPEED CONTROL ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/neo_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="13dp"
        android:paddingEnd="16dp"
        android:paddingBottom="13dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:text="@string/power"
            android:textColor="@color/neo_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <SeekBar
            android:id="@+id/speed_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_weight="1"
            android:max="255"
            android:maxHeight="22dp"
            android:minHeight="22dp"
            android:progress="255"
            android:progressDrawable="@drawable/neo_seekbar_track"
            android:thumb="@drawable/neo_seekbar_thumb" />

        <TextView
            android:id="@+id/speed_value"
            android:layout_width="44dp"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:gravity="end"
            android:text="255"
            android:textColor="@color/neo_text"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- ═══ MOTOR INDICATORS ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left motor -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:background="@drawable/neo_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/motor_left"
                android:textColor="@color/neo_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/left_motor_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:max="255"
                android:progress="0"
                android:progressDrawable="@drawable/neo_motor_bar" />

            <TextView
                android:id="@+id/left_motor_value"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:gravity="end"
                android:text="0"
                android:textColor="@color/neo_text"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right motor -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:background="@drawable/neo_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="@string/motor_right"
                android:textColor="@color/neo_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/right_motor_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="12dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:max="255"
                android:progress="0"
                android:progressDrawable="@drawable/neo_motor_bar" />

            <TextView
                android:id="@+id/right_motor_value"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:gravity="end"
                android:text="0"
                android:textColor="@color/neo_text"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
